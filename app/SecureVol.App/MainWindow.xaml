<Window x:Class="SecureVol.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureVol"
        Height="780"
        Width="1320"
        MinHeight="720"
        MinWidth="1180">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14"
                Margin="0,0,0,12"
                CornerRadius="8"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource PanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="SecureVol"
                               FontSize="26"
                               FontFamily="Consolas"
                               Foreground="{DynamicResource HeadingBrush}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="Local volume gate for VeraCrypt. Flat console mode."
                               Foreground="{DynamicResource MutedTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="24,0,24,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="StatusMessageTextBlock"
                               FontFamily="Consolas"
                               FontSize="13"
                               Foreground="{DynamicResource BodyTextBrush}"
                               Text="Loading local snapshot..." />
                    <TextBlock x:Name="BackendLatencyTextBlock"
                               Margin="0,4,0,0"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="backend: pending" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Margin="0,0,8,0"
                            Content="Refresh"
                            Click="RefreshButton_Click" />
                    <Button Margin="0,0,8,0"
                            Style="{DynamicResource AccentButtonStyle}"
                            Content="Enable"
                            Click="EnableProtectionButton_Click" />
                    <Button Style="{DynamicResource DangerButtonStyle}"
                            Content="Disable"
                            Click="DisableProtectionButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="12"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource PanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="allowlist"
                                       FontFamily="Consolas"
                                       FontSize="18"
                                       Foreground="{DynamicResource HeadingBrush}" />
                            <TextBlock x:Name="RuleCountTextBlock"
                                       Margin="14,1,0,0"
                                       FontFamily="Consolas"
                                       FontSize="18"
                                       Foreground="{DynamicResource AccentBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Content="Reload"
                                    Click="ReloadPolicyButton_Click" />
                            <Button Margin="0,0,8,0"
                                    Content="Remove"
                                    Click="RemoveRuleButton_Click" />
                            <Button Style="{DynamicResource AccentButtonStyle}"
                                    Content="Add App"
                                    Click="AddRuleButton_Click" />
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="AllowedAppsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="120" />
                            <DataGridTextColumn Header="EXECUTABLE" Binding="{Binding ImagePath}" Width="2.6*" />
                            <DataGridTextColumn Header="PUBLISHER" Binding="{Binding Publisher}" Width="1.2*" />
                            <DataGridTextColumn Header="USER" Binding="{Binding ExpectedUser}" Width="1.05*" />
                            <DataGridCheckBoxColumn Header="SIGNED" Binding="{Binding RequireSignature}" Width="75" />
                            <DataGridTextColumn Header="SHA256" Binding="{Binding Sha256}" Width="1.6*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,12"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource PanelBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="PROTECTION"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontFamily="Consolas" />
                        <TextBlock x:Name="ProtectionStateTextBlock"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   FontFamily="Consolas"
                                   FontSize="16"
                                   Foreground="{DynamicResource HeadingBrush}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,0"
                                   Text="VOLUME"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontFamily="Consolas" />
                        <TextBlock x:Name="ProtectedVolumeTextBlock"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="12,10,0,0"
                                   HorizontalAlignment="Right"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource BodyTextBrush}" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,10,0,0"
                                   Text="BACKEND"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontFamily="Consolas" />
                        <TextBlock x:Name="BackendStateTextBlock"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="12,10,0,0"
                                   HorizontalAlignment="Right"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource BodyTextBrush}" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,10,0,0"
                                   Text="DEFAULT USER"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontFamily="Consolas" />
                        <TextBlock x:Name="DefaultUserEchoTextBlock"
                                   Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="12,10,0,0"
                                   HorizontalAlignment="Right"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource BodyTextBrush}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,0,0,12"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource PanelBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="scope"
                                   FontFamily="Consolas"
                                   FontSize="18"
                                   Foreground="{DynamicResource HeadingBrush}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,6"
                                   Text="mounted drive"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                        <DockPanel Grid.Row="1" Margin="0,30,0,0">
                            <Button DockPanel.Dock="Right"
                                    Margin="8,0,0,0"
                                    Content="Apply"
                                    Click="ApplyVolumeButton_Click" />
                            <ComboBox x:Name="MountedVolumeComboBox"
                                      MinHeight="34" />
                        </DockPanel>

                        <TextBlock Grid.Row="2"
                                   Margin="0,10,0,6"
                                   Text="default expected user"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                        <DockPanel Grid.Row="2" Margin="0,30,0,0">
                            <Button DockPanel.Dock="Right"
                                    Margin="8,0,0,0"
                                    Content="Save"
                                    Click="SaveDefaultUserButton_Click" />
                            <TextBox x:Name="DefaultUserTextBox"
                                     MinHeight="34"
                                     VerticalContentAlignment="Center" />
                        </DockPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,0,0,12"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource PanelBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="recent denies"
                                   FontFamily="Consolas"
                                   FontSize="18"
                                   Foreground="{DynamicResource HeadingBrush}" />
                        <ListBox x:Name="RecentDeniesListBox"
                                 Grid.Row="1"
                                 Margin="0,10,0,0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 BorderThickness="1" />
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource PanelBrush}">
                    <StackPanel>
                        <TextBlock Text="tools"
                                   FontFamily="Consolas"
                                   FontSize="18"
                                   Foreground="{DynamicResource HeadingBrush}" />
                        <WrapPanel Margin="0,10,0,0">
                            <Button Margin="0,0,8,0"
                                    Content="Open Logs"
                                    Click="OpenLogsButton_Click" />
                            <Button Margin="0,0,8,0"
                                    Content="Open Config"
                                    Click="OpenConfigButton_Click" />
                            <Button Style="{DynamicResource DangerButtonStyle}"
                                    Content="Pause"
                                    Click="DisableProtectionButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
