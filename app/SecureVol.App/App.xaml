<Application x:Class="SecureVol.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#14161A" />
        <SolidColorBrush x:Key="PanelBrush" Color="#1B1E24" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#20242B" />
        <SolidColorBrush x:Key="BorderBrush" Color="#2D333B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#58A6FF" />
        <SolidColorBrush x:Key="AccentBrushStrong" Color="#1F6FEB" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F85149" />
        <SolidColorBrush x:Key="WarningBrush" Color="#D29922" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#3FB950" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8B949E" />
        <SolidColorBrush x:Key="BodyTextBrush" Color="#E6EDF3" />
        <SolidColorBrush x:Key="HeadingBrush" Color="#F0F6FC" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource AccentBrushStrong}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrushStrong}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="AlternatingRowBackground" Value="#242932" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
    </Application.Resources>
</Application>
