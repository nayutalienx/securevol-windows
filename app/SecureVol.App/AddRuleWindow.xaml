<Window x:Class="SecureVol.App.AddRuleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Allowed Application"
        Height="560"
        Width="760"
        MinHeight="560"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Add Allowed Application"
                       FontSize="26"
                       FontFamily="Bahnschrift SemiBold"
                       Foreground="{DynamicResource HeadingBrush}" />
            <TextBlock Margin="0,6,0,0"
                       Text="Pick an executable, inspect its signer and hash, then save it as an allow rule."
                       Foreground="{DynamicResource MutedTextBrush}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,12,16"
                       VerticalAlignment="Center"
                       Text="Executable"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <TextBox x:Name="ExecutablePathTextBox"
                     Grid.Row="0"
                     Grid.Column="1"
                     Margin="0,0,12,16"
                     MinHeight="36"
                     VerticalContentAlignment="Center" />
            <Button Grid.Row="0"
                    Grid.Column="2"
                    Margin="0,0,0,16"
                    Content="Browse"
                    Click="BrowseExecutableButton_Click" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Margin="0,0,12,16"
                       VerticalAlignment="Center"
                       Text="Rule Name"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <TextBox x:Name="RuleNameTextBox"
                     Grid.Row="1"
                     Grid.Column="1"
                     Grid.ColumnSpan="2"
                     Margin="0,0,0,16"
                     MinHeight="36"
                     VerticalContentAlignment="Center" />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Margin="0,0,12,16"
                       VerticalAlignment="Center"
                       Text="Expected User"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <TextBox x:Name="ExpectedUserTextBox"
                     Grid.Row="2"
                     Grid.Column="1"
                     Grid.ColumnSpan="2"
                     Margin="0,0,0,16"
                     MinHeight="36"
                     VerticalContentAlignment="Center" />

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Margin="0,0,12,16"
                       VerticalAlignment="Center"
                       Text="Publisher"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <TextBox x:Name="PublisherTextBox"
                     Grid.Row="3"
                     Grid.Column="1"
                     Grid.ColumnSpan="2"
                     Margin="0,0,0,16"
                     MinHeight="36"
                     VerticalContentAlignment="Center" />

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Margin="0,0,12,16"
                       VerticalAlignment="Center"
                       Text="SHA-256"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <TextBox x:Name="Sha256TextBox"
                     Grid.Row="4"
                     Grid.Column="1"
                     Margin="0,0,12,16"
                     MinHeight="36"
                     VerticalContentAlignment="Center" />
            <Button Grid.Row="4"
                    Grid.Column="2"
                    Margin="0,0,0,16"
                    Content="Inspect EXE"
                    Click="InspectExecutableButton_Click" />

            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Margin="0,0,12,16"
                       VerticalAlignment="Center"
                       Text="Signature"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <CheckBox x:Name="RequireSignatureCheckBox"
                      Grid.Row="5"
                      Grid.Column="1"
                      Grid.ColumnSpan="2"
                      Margin="0,0,0,16"
                      VerticalAlignment="Center"
                      Content="Require a valid Authenticode signature for this rule" />

            <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Margin="0,0,12,16"
                       VerticalAlignment="Top"
                       Text="Notes"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <TextBox x:Name="NotesTextBox"
                     Grid.Row="6"
                     Grid.Column="1"
                     Grid.ColumnSpan="2"
                     Margin="0,0,0,16"
                     MinHeight="72"
                     TextWrapping="Wrap"
                     AcceptsReturn="True" />

            <Border Grid.Row="7"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Padding="14"
                    CornerRadius="12"
                    Background="{DynamicResource PanelAltBrush}">
                <TextBlock x:Name="ExecutableFactsTextBlock"
                           Text="Choose an executable to prefill hash and signer details."
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,12,0"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Content="Cancel"
                    IsCancel="True" />
            <Button Content="Save Rule"
                    IsDefault="True"
                    Click="SaveRuleButton_Click" />
        </StackPanel>
    </Grid>
</Window>
